{
  "name": "alfajer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --cwd apps/signaling dev & bun --cwd apps/web dev",
    "test": "vitest run --dir apps/signaling/src && vitest run --dir apps/web/src",
    "lint": "eslint .",
    "lint:css": "stylelint \"**/*.svelte\" \"**/*.css\"",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@sveltejs/adapter-static": "^3.0.1",
    "@vite-pwa/sveltekit": "^0.6.1",
    "eslint": "^8.57.0",
    "eslint-plugin-svelte": "^2.35.1",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.2.5",
    "prettier-plugin-svelte": "^3.2.3",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^1.6.0"
  }
}
