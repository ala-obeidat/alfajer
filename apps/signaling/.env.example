# Copy to .env and fill in the values. Never commit the real .env.
PORT=3000

# Shared with the CoTURN config. 64 hex chars (32 bytes) is what
# update-secret.bat generates. NEVER set this to a literal example value.
TURN_STATIC_AUTH_SECRET=replace-me-with-a-fresh-64-char-hex-secret

# Comma-separated allowlist of frontend origins permitted to open
# WebSocket connections. Browsers from any other origin are rejected
# with close code 1008 to prevent CSWSH.
#
#   Production : MUST be set to one or more concrete https:// origins.
#                Setting this to '*' or leaving it empty makes the
#                signaling process refuse to start (see NODE_ENV below).
#   Development: leave blank to allow any origin during local testing.
ALLOWED_ORIGIN=http://localhost:5173

# Set to 'production' on the live deploy. The server hardens its defaults
# accordingly (silent logging, Origin allowlist enforced, etc).
NODE_ENV=development
